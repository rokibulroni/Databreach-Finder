#!/usr/bin/env bash

show_spinner() {
    local -r pid="${1}"
    local -r msg="${2:-Working...}"
    local -r delay='0.1'
    local spinstr=( '⠋' '⠙' '⠹' '⠸' '⠼' '⠴' '⠦' '⠧' '⠇' '⠏' )
    while kill -0 "${pid}" 2>/dev/null; do
        for (( i=0; i<${#spinstr[@]}; i++ )); do
            printf "\r\033[1;36m[%s]\033[0m %s" "${spinstr[$i]}" "${msg}"
            sleep "${delay}"
        done
    done
    printf "\r\033[1;32m[✓]\033[0m %s Done!     \n" "${msg}"
}

print_progress_bar() {
    local percent=$1
    local width=30
    local filled=$(( percent * width / 100 ))
    local empty=$(( width - filled ))
    printf "\r\033[1;34m[*] Setup Progress: [\033[1;32m"
    for ((i=0; i<filled; i++)); do printf "█"; done
    for ((i=0; i<empty; i++)); do printf "░"; done
    printf "\033[1;34m] %d%%\033[0m\n" "$percent"
}

echo -e "\033[1;36m====================================================\033[0m"
echo -e "\033[1;36m       Professor OSINT - Unified Web Installer      \033[0m"
echo -e "\033[1;36m====================================================\033[0m"
echo ""
echo -e "\033[1;37mPlease choose your Operating System:\033[0m"
echo -e "  1) macOS"
echo -e "  2) Linux (Debian/Ubuntu/Kali/Arch)"
echo -e "  3) Windows (via Git Bash / WSL)"
echo -e "  4) Exit"
echo ""

read -p "Enter your choice (1-4): " os_choice < /dev/tty

case $os_choice in
    1) OS="mac" ;;
    2) OS="linux" ;;
    3) OS="windows" ;;
    4) echo "Installation cancelled."; exit 0 ;;
    *) echo -e "\033[0;31mInvalid choice. Exiting.\033[0m"; exit 1 ;;
esac

check_and_install_git_py() {
    local pm_name=$1
    local install_cmd=$2
    local needs_git=0
    local needs_py=0
    
    if ! command -v git &>/dev/null; then needs_git=1; fi
    if ! command -v python3 &>/dev/null && ! command -v python &>/dev/null; then needs_py=1; fi
    
    if [ $needs_git -eq 0 ] && [ $needs_py -eq 0 ]; then
        echo -e "\033[1;32m[*] Git and Python are already installed! Skipping...\033[0m"
        return
    fi
    
    echo -e "\033[1;33m[*] Git and/or Python are missing.\033[0m"
    read -p "Can I use '$pm_name' to install them? (y/n): " pm_choice < /dev/tty
    if [[ "$pm_choice" == "y" || "$pm_choice" == "Y" ]]; then
        eval "$install_cmd"
    else
        echo -e "\033[1;31m[!] Please install Git and Python manually.\033[0m"
    fi
}

echo ""
read -p "Do you want me to check and install system dependencies (Git, Python3)? (y/n): " dep_choice < /dev/tty
if [[ "$dep_choice" == "y" || "$dep_choice" == "Y" ]]; then
    echo -e "\033[1;34m[*] Checking system dependencies for $OS...\033[0m"
    if [ "$OS" == "mac" ]; then
        if ! command -v brew &>/dev/null; then
            echo -e "\033[1;33m[*] Homebrew is not installed.\033[0m"
            read -p "Do you want to install Homebrew? (y/n): " brew_choice < /dev/tty
            if [[ "$brew_choice" == "y" || "$brew_choice" == "Y" ]]; then
                /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
                # Add brew to PATH for this script session
                if [ -x "/opt/homebrew/bin/brew" ]; then
                    eval "$(/opt/homebrew/bin/brew shellenv)"
                fi
            fi
        fi
        
        if command -v brew &>/dev/null; then
            check_and_install_git_py "Homebrew (brew)" "brew install git python3"
        else
            echo -e "\033[1;31m[!] Without Homebrew, please install Git and Python manually.\033[0m"
        fi
    elif [ "$OS" == "linux" ]; then
        if command -v apt-get &>/dev/null; then
            check_and_install_git_py "apt-get" "sudo apt-get update && sudo apt-get install -y git python3 python3-venv python3-pip curl"
        elif command -v pacman &>/dev/null; then
            check_and_install_git_py "pacman" "sudo pacman -Sy --noconfirm git python python-pip python-virtualenv curl"
        else
            echo -e "\033[0;31m[!] Supported package manager not found! Please install Git and Python3 manually.\033[0m"
        fi
    elif [ "$OS" == "windows" ]; then
        if command -v winget &>/dev/null; then
            check_and_install_git_py "winget" "winget install --id Git.Git -e --source winget && winget install --id Python.Python.3.11 -e --source winget"
        else
            echo -e "\033[1;33m[!] On Windows, please ensure you have installed Git and Python from python.org.\033[0m"
            read -p "Press Enter to continue once you have Git and Python installed..." < /dev/tty
        fi
    fi
fi

echo ""
read -p "Do you want to install VPN dependencies (OpenVPN, WireGuard) for Layer-3 security? (y/n): " vpn_choice < /dev/tty
if [[ "$vpn_choice" == "y" || "$vpn_choice" == "Y" ]]; then
    echo -e "\033[1;34m[*] Installing VPN dependencies for $OS...\033[0m"
    if [ "$OS" == "mac" ]; then
        if command -v brew &>/dev/null; then
            brew install openvpn wireguard-tools
        else
            echo -e "\033[0;31m[!] Homebrew not found. Please install openvpn and wireguard-tools manually.\033[0m"
        fi
    elif [ "$OS" == "linux" ]; then
        if command -v apt-get &>/dev/null; then
            sudo apt-get install -y openvpn wireguard
        elif command -v pacman &>/dev/null; then
            sudo pacman -Sy --noconfirm openvpn wireguard-tools
        else
            echo -e "\033[0;31m[!] Supported package manager not found! Please install VPN tools manually.\033[0m"
        fi
    elif [ "$OS" == "windows" ]; then
        echo -e "\033[1;33m[!] Windows Layer-3 VPN routing is currently not natively supported via CLI installer.\033[0m"
    fi
fi

echo ""
if command -v docker &>/dev/null; then
    echo -e "\033[1;32m[*] Docker is already installed! Skipping Docker setup...\033[0m"
else
    read -p "Do you want to install Docker (Optional)? (y/n): " docker_choice < /dev/tty
    if [[ "$docker_choice" == "y" || "$docker_choice" == "Y" ]]; then
        echo -e "\033[1;34m[*] Installing Docker...\033[0m"
        if [ "$OS" == "mac" ]; then
            if command -v brew &>/dev/null; then
                read -p "Can I use Homebrew (brew) to install Docker Desktop? (y/n): " brew_docker < /dev/tty
                if [[ "$brew_docker" == "y" || "$brew_docker" == "Y" ]]; then
                    brew install --cask docker
                fi
            else
                echo -e "\033[0;31m[!] Homebrew not found. Please install Docker manually.\033[0m"
            fi
        elif [ "$OS" == "linux" ]; then
            read -p "Can I use the official Docker installation script (get.docker.com)? (y/n): " linux_docker < /dev/tty
            if [[ "$linux_docker" == "y" || "$linux_docker" == "Y" ]]; then
                curl -fsSL https://get.docker.com -o get-docker.sh
                sudo sh get-docker.sh
                rm get-docker.sh
            fi
        elif [ "$OS" == "windows" ]; then
            if command -v winget &>/dev/null; then
                read -p "Can I use 'winget' to install Docker Desktop? (y/n): " win_docker < /dev/tty
                if [[ "$win_docker" == "y" || "$win_docker" == "Y" ]]; then
                    winget install --id Docker.DockerDesktop -e --source winget
                fi
            else
                echo -e "\033[0;31m[!] winget not found. Please install Docker Desktop manually.\033[0m"
            fi
        fi
    fi
fi

echo ""
echo -e "\033[1;34m[*] Proceeding with Professor OSINT setup...\033[0m"
print_progress_bar 10

INSTALL_DIR="$HOME/.professor_osint"
BIN_DIR="$HOME/.local/bin"

if [ -d "$INSTALL_DIR/.git" ]; then
    echo -e "\033[1;33m[*] Existing Git installation found. Updating...\033[0m"
    cd "$INSTALL_DIR"
    git pull origin main
else
    echo -e "\033[1;34m[*] Cleaning old installation and cloning repository...\033[0m"
    rm -rf "$INSTALL_DIR"
    git clone https://github.com/rokibulroni/professor-osint.git "$INSTALL_DIR"
    cd "$INSTALL_DIR"
fi

print_progress_bar 40

# Check for Python 3
if command -v python3 &>/dev/null; then
    PYTHON_CMD="python3"
elif command -v python &>/dev/null && python --version | grep -q "Python 3"; then
    PYTHON_CMD="python"
else
    echo -e "\033[0;31m[!] Error: Python 3 is not installed or not in PATH.\033[0m"
    exit 1
fi

VENV_DIR="$INSTALL_DIR/venv"
echo -e "\033[1;34m[*] Setting up Virtual Environment...\033[0m"
$PYTHON_CMD -m venv "$VENV_DIR" &
show_spinner $! "Creating Virtualenv"

print_progress_bar 60

echo -e "\033[1;34m[*] Installing Python requirements...\033[0m"
if [ "$OS" == "windows" ]; then
    source "$VENV_DIR/Scripts/activate"
else
    source "$VENV_DIR/bin/activate"
fi

python -m pip install --upgrade pip
pip install -r requirements.txt
deactivate

print_progress_bar 90

mkdir -p "$BIN_DIR"

if [ "$OS" == "windows" ]; then
    WRAPPER_SCRIPT="$BIN_DIR/professor-osint.bat"
    echo -e "\033[1;34m[*] Creating global command wrapper...\033[0m"
    cat << EOF > "$WRAPPER_SCRIPT"
@echo off
call "$VENV_DIR/Scripts/activate.bat"
python "$INSTALL_DIR/professor_osint.py" %*
call deactivate
EOF

    WEB_WRAPPER="$BIN_DIR/professor-osint-web.bat"
    cat << EOF > "$WEB_WRAPPER"
@echo off
call "$VENV_DIR/Scripts/activate.bat"
python "$INSTALL_DIR/web_app.py" %*
call deactivate
EOF

    UNINSTALL_WRAPPER="$BIN_DIR/professor-osint-uninstall.bat"
    cat << EOF > "$UNINSTALL_WRAPPER"
@echo off
echo [*] Uninstalling Professor OSINT...
rmdir /S /Q "$INSTALL_DIR"
del "$WRAPPER_SCRIPT"
del "$WEB_WRAPPER"
del "%~f0"
echo [+] Successfully uninstalled Professor OSINT.
EOF
else
    WRAPPER_SCRIPT="$BIN_DIR/professor-osint"
    echo -e "\033[1;34m[*] Creating global command wrappers...\033[0m"
    cat << EOF > "$WRAPPER_SCRIPT"
#!/usr/bin/env bash
source "$VENV_DIR/bin/activate"
python "$INSTALL_DIR/professor_osint.py" "\$@"
deactivate
EOF
    chmod +x "$WRAPPER_SCRIPT"

    WEB_WRAPPER="$BIN_DIR/professor-osint-web"
    cat << EOF > "$WEB_WRAPPER"
#!/usr/bin/env bash
source "$VENV_DIR/bin/activate"
python "$INSTALL_DIR/web_app.py" "\$@"
deactivate
EOF
    chmod +x "$WEB_WRAPPER"

    UNINSTALL_WRAPPER="$BIN_DIR/professor-osint-uninstall"
    cat << EOF > "$UNINSTALL_WRAPPER"
#!/usr/bin/env bash
echo -e "\033[1;31m[*] Uninstalling Professor OSINT...\033[0m"
rm -rf "$INSTALL_DIR"
rm -f "$WRAPPER_SCRIPT"
rm -f "$WEB_WRAPPER"
rm -f "\$0"
echo -e "\033[1;32m[+] Successfully completely uninstalled Professor OSINT.\033[0m"
EOF
    chmod +x "$UNINSTALL_WRAPPER"
fi

print_progress_bar 100

echo -e "\033[1;32m====================================================\033[0m"
echo -e "\033[1;32m   Installation Successful! \033[0m"
echo -e "\033[1;32m====================================================\033[0m"
echo -e "\033[1;37mYou can now run the tool from anywhere using the commands:\033[0m"
echo -e "\n    \033[1;33mprofessor-osint --help\033[0m   (For CLI)"
echo -e "    \033[1;33mprofessor-osint-web\033[0m      (For Web Dashboard)"
echo -e "    \033[1;31mprofessor-osint-uninstall\033[0m (To remove everything)\n"

# Check if ~/.local/bin is in PATH
if [[ "$OS" != "windows" ]]; then
    if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
        echo -e "\033[1;31m[!] NOTE: $HOME/.local/bin is not in your PATH.\033[0m"
        echo -e "\033[1;37mPlease add the following line to your ~/.bashrc or ~/.zshrc:\033[0m"
        echo -e "\033[1;33mexport PATH=\"\$HOME/.local/bin:\$PATH\"\033[0m"
    fi
else
    echo -e "\033[1;31m[!] NOTE: Make sure $HOME\.local\bin is added to your Windows PATH environment variable.\033[0m"
fi
