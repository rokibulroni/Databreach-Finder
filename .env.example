# Optional API keys for Professor OSINT.
# Copy this file to `.env` and fill in the keys you have. Any key you supply
# upgrades that engine from anonymous scraping to the official API; missing
# keys are ignored and the tool falls back gracefully. Requires python-dotenv
# (already in requirements.txt) — without it, plain environment variables still work.
#
# TIP: instead of editing this file by hand, run `professor-osint --config-api`,
# an interactive wizard that validates each key and saves it to a user-global
# ~/.professor_osint.env (chmod 600) that works from any directory. Precedence:
#   real environment var  >  project .env  >  ~/.professor_osint.env

# Shodan — used by --spider (Attack Surface Mapping). With a key the tool queries
# the authenticated api.shodan.io host endpoint instead of the anonymous InternetDB.
SHODAN_API_KEY=

# VirusTotal — used by --harvester. Adds passive-DNS subdomains and a domain
# reputation snapshot (throttled to the free tier's 4 requests/minute).
VIRUSTOTAL_API_KEY=

# Hunter.io — used by --harvester. Adds structured employee emails via the
# domain-search endpoint on top of the scraped results.
HUNTER_API_KEY=

# ---------------------------------------------------------------------------
# Social X-Ray (--social-xray) EXPERIMENTAL platforms.
# ---------------------------------------------------------------------------
# Instagram — anonymous access is largely blocked, so extraction uses a
# logged-in session. Copy the `sessionid` cookie value from a browser where you
# are logged into a THROWAWAY/research account (using a session carries
# account-ban risk). INSTAGRAM_USERNAME is optional but improves reliability.
# Requires: pip install 'professor-osint[social]'
INSTAGRAM_SESSIONID=
INSTAGRAM_USERNAME=

# Facebook — no key needed. Uses headless Playwright Chromium; run once:
#   pip install 'professor-osint[social]' && playwright install chromium

# ---------------------------------------------------------------------------
# AI Threat Intelligence (--ai-analyze). Set the key for whichever cloud
# provider you configure via `professor-osint --config-ai`. Local providers
# (Ollama, LM Studio) need NO key. Provider/model/endpoint prefs are stored
# separately in ~/.professor_osint_config.json.
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
